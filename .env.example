# EyeGate demo configuration

EYEGATE_ENV=dev
EYEGATE_HOST=0.0.0.0
EYEGATE_PORT=8000
EYEGATE_DUMMY_HW=1

# Demo / auto-approve
EYEGATE_DEMO_MODE=1
AUTO_APPROVE_REGISTRATION=1

# Vision / camera (RTSP from Luckfox via ADB-forward)
VISION_MODE=real           # dummy | real
CAMERA_RTSP_URL=rtsp://<WINDOWS_HOST>:8554/live/0
RTSP_TRANSPORT=tcp         # tcp | udp
FFMPEG_PATH=ffmpeg         # or tools/ffmpeg/ffmpeg
VISION_CAMERA_BACKEND=ffmpeg   # opencv | ffmpeg | gstreamer
VISION_CAMERA_INDEX=0
VISION_ROTATE=0                # 0 | 90 | 180 | 270
VISION_FLIP=none               # none | h | v | hv

# Capture robustness
VISION_OPEN_TIMEOUT_MS=5000
VISION_READ_TIMEOUT_MS=2500
VISION_RECONNECT_BACKOFF_MS=200
VISION_RECONNECT_BACKOFF_MAX_MS=5000

# Recognition tuning
VISION_DETECTOR_THRESHOLD=0.7  # alias: VISION_DET_SCORE
VISION_MATCH_THRESHOLD=0.6
VISION_MATCH_METRIC=l2         # l2 | cosine
VISION_SMOOTH_WINDOW=5
VISION_SMOOTH_HITS=3
VISION_SMOOTH_TTL=2
VISION_SMOOTH_SCORE_JITTER=0.08
VISION_SMOOTH_IOU_THRESHOLD=0.3
VISION_TTL_SEC=2.0
VISION_AUTO_DOWNLOAD=0
VISION_MODEL_DET=models/face_detection_yunet_2023mar.onnx
VISION_MODEL_REC=models/face_recognition_sface_2021dec.onnx

# Background / people count
BG_HISTORY=200
BG_VAR_THRESHOLD=40.0
PEOPLE_MIN_AREA=5000

# Timeouts (seconds)
EYEGATE_ENTER_TIMEOUT=15
EYEGATE_CHECK_TIMEOUT=10
EYEGATE_EXIT_TIMEOUT=15
EYEGATE_ALARM_TIMEOUT=60

# Policy
ALLOW_MULTI_KNOWN=0
REQUIRE_FACE_MATCH_FOR_DOOR2=1
MAX_PEOPLE_ALLOWED=1
DOOR1_CLOSE_STABILIZE_MS=1500
ROOM_CHECK_SAMPLES=5

# Door auto-close (seconds)
DOOR_AUTO_CLOSE_SEC=5
DOOR1_AUTO_CLOSE_SEC=0
DOOR2_AUTO_CLOSE_SEC=0
# Legacy: SIM_AUTO_CLOSE_MS=0

# Sensors / serial bridge (sim | serial)
SENSOR_MODE=sim
SENSOR_SERIAL_PORT=COM5
SENSOR_SERIAL_BAUD=115200

# Security
# ADMIN_TOKEN=demo-admin-token
# AUTH_SECRET=change-me
# ADMIN_LOGIN=admin
# ADMIN_PASS=admin123
# ADMIN_CARD_ID=ADMINCARD

# Demo person (seeded when EYEGATE_DEMO_MODE=1)
DEMO_PERSON_LOGIN=shapovalov
DEMO_PERSON_NAME=Shapovalov Artem
DEMO_PERSON_PIN=1234
DEMO_PERSON_CARD_ID=SHAPCARD

# DB path (defaults to data/eyegate_scud.db)
# EYEGATE_DB_PATH=/opt/eyegate-mantrap/data/eyegate_scud.db
# EYEGATE_DB_TIMEOUT=5.0
# EYEGATE_DB_JOURNAL_MODE=DELETE   # recommended on Windows/WSL UNC paths
