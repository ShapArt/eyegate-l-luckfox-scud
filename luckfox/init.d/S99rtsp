#!/bin/sh

DAEMON="__RTSP_BIN__"
PIDFILE="/var/run/rtsp.pid"

start() {
  if [ ! -x "$DAEMON" ]; then
    echo "RTSP binary not found: $DAEMON"
    return 1
  fi
  if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
    echo "RTSP already running"
    return 0
  fi
  echo "Starting RTSP: $DAEMON"
  "$DAEMON" >/dev/null 2>&1 &
  echo $! > "$PIDFILE"
}

stop() {
  if [ -f "$PIDFILE" ]; then
    kill "$(cat "$PIDFILE")" 2>/dev/null || true
    rm -f "$PIDFILE"
  fi
}

status() {
  if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
    echo "RTSP running (pid $(cat "$PIDFILE"))"
    return 0
  fi
  echo "RTSP stopped"
  return 1
}

case "$1" in
  start) start ;;
  stop) stop ;;
  restart) stop; start ;;
  status) status ;;
  *) echo "Usage: $0 {start|stop|restart|status}"; exit 1 ;;
esac
